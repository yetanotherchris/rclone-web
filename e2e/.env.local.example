# Opt-in credentials for the Backblaze B2 bucket copy e2e test.
#
# Copy this file to `e2e/.env.local` (gitignored) and fill in real values.
# When `e2e/.env.local` is absent, the B2 spec (b2-copy-job.spec.ts) is skipped
# and `npm test` runs only the hermetic local-to-local tests.
#
# RCLONEWEB_ is just a namespace prefix (the project is rclone-web) so these
# vars don't collide with anything else in your shell.
#
# ACCOUNT/KEY are a B2 application key's keyID and applicationKey (rclone's
# native "b2" backend account/key). The test copies a folder to another folder
# WITHIN one bucket: set SRC_BUCKET and DST_BUCKET to the same bucket name. It
# only ever touches the <bucket>/<prefix>/src and <bucket>/<prefix>/dst paths,
# and purges them before and after the run.

RCLONEWEB_E2E_B2_ACCOUNT=your-b2-key-id
RCLONEWEB_E2E_B2_KEY=your-b2-application-key
RCLONEWEB_E2E_B2_SRC_BUCKET=rclone-web-e2e-tests
RCLONEWEB_E2E_B2_DST_BUCKET=rclone-web-e2e-tests

# Optional: path prefix isolated within the bucket. Default is e2e.
RCLONEWEB_E2E_B2_PREFIX=e2e
